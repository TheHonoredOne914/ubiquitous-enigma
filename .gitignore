```gitignore
# Dependencies
node_modules/

# Build outputs
dist/
build/
*.js.map
*.ts.map
*.jsx.map
*.tsx.map

# Environment variables
.env
.env.local
.env.*

# Logs
*.log

# OS generated files
.DS_Store
Thumbs.db

# Editor files
.vscode/
.idea/
*.swp
*.swo
*.tmp

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
.coverage
htmlcov/
.coverage.*
.pytest_cache/
.mypy_cache/

# Node.js
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Compiled and binary files
*.exe
*.dll
*.so
*.a
*.o
*.out
*.class

# Compressed files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst

# Coverage directory used by tools like Istanbul
coverage/
```