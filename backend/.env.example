# Supabase Configuration
# Get these from your Supabase project: https://app.supabase.com/project/_/settings/api
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Optional: Service role key (for admin operations, keep secret!)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Application Settings
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# Database (if using SQLite as fallback)
DATABASE_URL=sqlite:./bestdel.db

# Redis (optional - leave empty to disable)
# REDIS_URL=redis://localhost:6379

# Retrieval Cache Settings
RETRIEVAL_CACHE_ENABLED=true
RETRIEVAL_CACHE_DEFAULT_TTL_SECONDS=604800
RETRIEVAL_CACHE_NEGATIVE_TTL_SECONDS=3600
RETRIEVAL_CACHE_FRESH_TTL_SECONDS=43200
RETRIEVAL_CACHE_MAX_ENTRY_BYTES=5242880
RETRIEVAL_CACHE_SCHEMA_VERSION=1
RETRIEVAL_CACHE_DEBUG=true

# Concurrency Limits
MAX_DEEP_RESEARCH_CONCURRENCY=3
MAX_WEB_SEARCH_CONCURRENCY=8

# Stream Timeout (ms)
STREAM_TIMEOUT_MS=600000

# ===========================================
# API KEYS FOR AI MODELS & WEB SEARCH TOOLS
# Add your keys below. Users can also provide keys in the UI.
# Leave empty if you don't have them.
# ===========================================

# AI Model Providers (Optional - users can select in UI)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
GEMINI_API_KEY=
CEREBRAS_API_KEY=
NVIDIA_API_KEY=
OPENROUTER_API_KEY=
GITHUB_TOKEN=
OLLAMA_API_KEY=

# Web Search & Scraping Tools
TAVILY_API_KEY=
SERPER_KEY=
BRAVE_KEY=
EXA_API_KEY=
JINA_KEY=
FIRECRAWL_API_KEY=
SCRAPERAPI_KEY=
SCRAPINGBEE_API_KEY=
ZENROWS_API_KEY=
GEEKFLARE_API_KEY=

# ScraperAPI Settings (optional)
SCRAPERAPI_ENABLED=false
SCRAPERAPI_COUNTRY_CODE=us
SCRAPERAPI_TIMEOUT_MS=30000
SCRAPERAPI_MAX_CONCURRENCY=5
SCRAPERAPI_RENDER=false
SCRAPERAPI_PREMIUM_PROXY=false
SCRAPERAPI_MAX_HTML_BYTES=10485760

# ScapingBee Settings (optional)
SCRAPINGBEE_ENABLED=false
SCRAPINGBEE_COUNTRY_CODE=us
SCRAPINGBEE_TIMEOUT_MS=30000
SCRAPINGBEE_RENDER_JS=false
SCRAPINGBEE_PREMIUM_PROXY=false

# NVIDIA Settings (optional)
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
